# Copy this file to `.env` and fill in real values.
# The real `.env` is gitignored — NEVER commit it.

# --- App ---
APP_NAME=JobLens
APP_ENV=development
LOG_LEVEL=INFO

# --- Database ---
# Default: local SQLite file. Swap to a Postgres URL later for deploy.
DATABASE_URL=sqlite:///./joblens.db

# --- CORS ---
# Origins that can call the API. Vite dev server runs on 5173.
FRONTEND_ORIGIN=http://localhost:5173

# --- Gmail OAuth (added Phase 2) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Telegram (added Phase 4) ---
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
